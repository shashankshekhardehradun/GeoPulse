# GeoPulse Environment Configuration
# Copy this file to .env and fill in your API keys

# OpenSky Network OAuth Credentials
# Get yours at: https://opensky-network.org/
OPENSKY_CLIENT_ID=your_client_id
OPENSKY_CLIENT_SECRET=your_client_secret

# ADS-B Exchange RapidAPI Key (Optional)
# Get yours free at: https://rapidapi.com/adsbx/api/adsbexchange-com1
# 1. Sign up for RapidAPI
# 2. Subscribe to the free tier of ADS-B Exchange API
# 3. Copy your X-RapidAPI-Key from the API playground
ADSB_API_KEY=your_rapidapi_key
